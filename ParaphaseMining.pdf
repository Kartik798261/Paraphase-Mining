    {
      "cell_type": "code",
      "source": [
        "s1 = \"The is on the mat\"\n",
        "s2 = \"A Cat is sitting on the mat\"\n",
        "emb1 = model.encode(s1)\n",
        "emb2 = model.encode(s2)\n",
        "sim_score =util.cos_sim(emb1, emb2)\n",
        "sim_score\n"
      ],
      "metadata": {
