    {
      "cell_type": "code",
      "source": [
        "from sentence_transformers import SentenceTransformer,util\n",
        "from sentence_transformers.util import paraphrase_mining\n",
        "model = SentenceTransformer(\"all-MiniLM-l6-v2\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 49,
